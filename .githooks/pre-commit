#!/usr/bin/env sh

set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

changed_files=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$changed_files" ] && exit 0

go_files=$(printf '%s\n' "$changed_files" | grep -E '\.go$' || true)
if [ -n "$go_files" ]; then
	if command -v gofmt >/dev/null 2>&1; then
		echo "Formatting staged Go files"
		printf '%s\n' "$go_files" | while IFS= read -r file; do
			[ -z "$file" ] && continue
			gofmt -w "$file"
			git add "$file"
		done
	else
		echo "gofmt not found - skipping Go formatting"
	fi
fi

if printf '%s\n' "$changed_files" | grep -Eq '^web/src/ar/'; then
	if command -v yarn >/dev/null 2>&1; then
		echo "Running web lint-staged checks for web/src/ar changes"
		cd "$repo_root/web"
		npx lint-staged
	else
		echo "yarn not found - skipping web lint-staged"
	fi
fi
